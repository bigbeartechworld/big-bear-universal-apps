{
  "spec_version": "1.0",
  "metadata": {
    "id": "seerr",
    "name": "Seerr",
    "description": "Seerr is a free and open source software application for managing requests for your media library. It is the successor to Overseerr and Jellyseerr, bringing support for Jellyfin, Plex, and Emby media servers.",
    "tagline": "Media request management for Jellyfin, Plex, and Emby",
    "version": "v3.2.0",
    "author": "BigBearCommunity",
    "developer": "Seerr Team",
    "category": "BigBearCasaOS",
    "license": "MIT",
    "homepage": "https://github.com/seerr-team/seerr",
    "source": "big-bear-universal",
    "created": "2026-04-13T00:00:00Z",
    "updated": "2026-04-19T20:39:59.498Z"
  },
  "visual": {
    "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/seerr.png",
    "thumbnail": "",
    "screenshots": [],
    "logo": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/seerr.png"
  },
  "resources": {
    "youtube": "",
    "documentation": "https://docs.seerr.dev",
    "repository": "https://github.com/seerr-team/seerr",
    "issues": "https://github.com/seerr-team/seerr/issues",
    "support": "https://community.bigbeartechworld.com/"
  },
  "technical": {
    "architectures": [
      "amd64",
      "arm64"
    ],
    "platform": "linux",
    "main_service": "app",
    "default_port": "5056",
    "main_image": "seerr/seerr",
    "compose_file": "docker-compose.yml"
  },
  "deployment": {
    "environment_variables": [
      {
        "name": "LOG_LEVEL",
        "default": "debug",
        "description": "Log level",
        "required": false
      },
      {
        "name": "TZ",
        "default": "",
        "description": "Timezone",
        "required": false
      }
    ],
    "volumes": [
      {
        "container": "/app/config",
        "description": "Container Path: /app/config"
      }
    ],
    "ports": [
      {
        "container": "5055",
        "host": "5056",
        "protocol": "tcp",
        "description": "Container Port: 5055"
      }
    ]
  },
  "ui": {
    "scheme": "http",
    "path": "",
    "tips": {
      "after_install": {
        "en_us": "Migrating from Jellyseerr? Seerr auto-migrates your data on first startup. Ensure the config directory is owned by UID 1000 (the node user)."
      }
    }
  },
  "compatibility": {
    "casaos": {
      "supported": true,
      "port_map": "5056",
      "volume_mappings": {
        "seerr_config": "/DATA/AppData/$AppID/config"
      },
      "port": "5056"
    },
    "portainer": {
      "supported": true,
      "template_type": 2,
      "categories": [
        "BigBearCasaOS",
        "selfhosted"
      ],
      "administrator_only": false,
      "port": "5056"
    },
    "runtipi": {
      "supported": true,
      "tipi_version": 1,
      "supported_architectures": [
        "amd64",
        "arm64"
      ],
      "volume_mappings": {
        "seerr_config": "config"
      },
      "port": "5056"
    },
    "dockge": {
      "supported": true,
      "file_based": true,
      "port": "5056"
    },
    "cosmos": {
      "supported": true,
      "servapp": true,
      "routes_required": true,
      "port": "5056"
    },
    "umbrel": {
      "supported": true,
      "manifest_version": 1,
      "volume_mappings": {
        "seerr_config": "config"
      },
      "port": "5056"
    }
  },
  "tags": [
    "selfhosted",
    "docker",
    "bigbear",
    "bigbearcasaos",
    "container",
    "media",
    "requests"
  ]
}
