{
  "spec_version": "1.0",
  "metadata": {
    "id": "passwordpusher-v2",
    "name": "Password Pusher v2",
    "description": "Password Pusher is an open source application to communicate passwords over the web. Links to passwords expire after a certain number of views and/or time has passed.",
    "tagline": "Give your users the tools to be secure by default.",
    "version": "2.6.3",
    "author": "BigBearTechWorld",
    "developer": "pglombardo",
    "category": "BigBearCasaOS",
    "license": "",
    "homepage": "https://hub.docker.com/r/pglombardo/pwpush",
    "source": "big-bear-universal",
    "created": "2026-04-12T00:00:00Z",
    "updated": "2026-05-01T17:04:07.997Z"
  },
  "visual": {
    "icon": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/password-pusher.png",
    "thumbnail": "",
    "screenshots": [],
    "logo": "https://cdn.jsdelivr.net/gh/selfhst/icons/png/password-pusher.png"
  },
  "resources": {
    "youtube": "https://youtu.be/U17LWqXfOmU",
    "documentation": "https://docs.pwpush.com/docs/upgrading/",
    "repository": "",
    "issues": "",
    "support": "https://community.bigbeartechworld.com/"
  },
  "technical": {
    "architectures": [
      "amd64",
      "arm64"
    ],
    "platform": "linux",
    "main_service": "big-bear-pwpush-v2",
    "default_port": "5101",
    "main_image": "pglombardo/pwpush",
    "compose_file": "docker-compose.yml"
  },
  "deployment": {
    "environment_variables": [
      {
        "name": "PWP__PW__EXPIRE_AFTER_DAYS_DEFAULT",
        "default": "1",
        "description": "Password Expire After Days Default",
        "required": false
      },
      {
        "name": "PWP__PW__EXPIRE_AFTER_VIEWS_MIN",
        "default": "1",
        "description": "Password Expire After Views Min",
        "required": false
      },
      {
        "name": "PWP__PW__RETRIEVAL_STEP_DEFAULT",
        "default": "true",
        "description": "Password Retrieval Step Default",
        "required": false
      }
    ],
    "volumes": [
      {
        "container": "/opt/PasswordPusher/storage",
        "description": "Container Path: /opt/PasswordPusher/storage"
      }
    ],
    "ports": [
      {
        "container": "5100",
        "host": "5101",
        "protocol": "tcp",
        "description": "Password Pusher v2 web interface (port 5101 to avoid conflict with v1's 5100)"
      }
    ]
  },
  "ui": {
    "scheme": "http",
    "path": "",
    "tips": {
      "before_install": {
        "en_us": "NEW APP - PASSWORD PUSHER V2\n\nThis is a SEPARATE app from 'Password Pusher (Legacy)' (v1.x). Both can run simultaneously.\n\nPassword Pusher v2 breaking changes:\n- MySQL/MariaDB dropped entirely; now uses PostgreSQL\n- 'enable_logins' removed; use 'allow_anonymous', 'disable_signups', 'disable_logins'\n- URL/file/QR pushes now enabled by default\n\nFOR MIGRATION FROM V1:\n- Do NOT uninstall your existing Password Pusher (Legacy) app\n- Data migration from MariaDB to PostgreSQL is required\n- See: https://docs.pwpush.com/docs/upgrading/"
      }
    }
  },
  "compatibility": {
    "casaos": {
      "supported": true,
      "port_map": "5101",
      "volume_mappings": {
        "passwordpusher-v2_postgres": "/DATA/AppData/$AppID/postgres",
        "passwordpusher-v2_storage": "/DATA/AppData/$AppID/storage"
      },
      "port": "5101"
    },
    "portainer": {
      "supported": true,
      "template_type": 2,
      "categories": [
        "BigBearCasaOS",
        "selfhosted"
      ],
      "administrator_only": false,
      "port": "5101"
    },
    "runtipi": {
      "supported": true,
      "tipi_version": 1,
      "supported_architectures": [
        "amd64",
        "arm64"
      ],
      "volume_mappings": {
        "passwordpusher-v2_postgres": "postgres",
        "passwordpusher-v2_storage": "storage"
      },
      "port": "5101"
    },
    "dockge": {
      "supported": true,
      "file_based": true,
      "port": "5101"
    },
    "cosmos": {
      "supported": true,
      "servapp": true,
      "routes_required": true,
      "port": "5101"
    },
    "umbrel": {
      "supported": true,
      "manifest_version": 1,
      "volume_mappings": {
        "passwordpusher-v2_postgres": "postgres",
        "passwordpusher-v2_storage": "storage"
      },
      "port": "5101"
    }
  },
  "tags": [
    "selfhosted",
    "docker",
    "bigbear",
    "bigbearcasaos",
    "container"
  ]
}
