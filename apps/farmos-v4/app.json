  "technical": {
    "architectures": [
      "amd64",
      "arm64"
    ],
    "platform": "linux",
    "main_service": "big-bear-farmos-v4",
    "default_port": "8083",
    "main_image": "farmos/farmos",
    "compose_file": "docker-compose.yml"
  },
  "deployment": {
    "environment_variables": [],
    "volumes": [
      {
        "container": "/opt/drupal/web/sites",
        "description": "Container Path: /opt/drupal/web/sites"
      }
    ],
    "ports": [
      {
        "container": "80",
        "host": "8083",
        "protocol": "tcp",
        "description": "FarmOS v4 web interface (port 8083 to avoid conflict with v3's 8080)"
      }
    ]
  },
  "ui": {
    "scheme": "http",
    "path": "",
    "tips": {
      "before_install": {
        "en_us": "NEW APP - FARMOS V4\n\nThis is a SEPARATE app from 'FarmOS (Legacy)' (v3.x). Both can run simultaneously.\n\nFarmOS v4 requires:\n- PHP 8.4 (Drupal 11)\n- MariaDB 10.6+ (this app uses MariaDB 10.6)\n\nFOR MIGRATION FROM V3:\n- You MUST be on the latest farmOS 3.x before upgrading\n- Do NOT uninstall your existing FarmOS (Legacy) app\n- Create backups before migrating\n- See: https://farmos.org/hosting/install/"
      }
    }
  },
  "compatibility": {
    "casaos": {
      "supported": true,
      "port_map": "8083",
      "volume_mappings": {
        "farmos-v4_db": "/DATA/AppData/$AppID/db",
        "farmos-v4_sites": "/DATA/AppData/$AppID/sites"
      },
      "port": "8083"
    },
    "portainer": {
      "supported": true,
      "template_type": 2,
      "categories": [
        "BigBearCasaOS",
        "selfhosted"
      ],
      "administrator_only": false,
      "port": "8083\n3307"
    },
    "runtipi": {
      "supported": true,
      "tipi_version": 1,
      "supported_architectures": [
        "amd64",
        "arm64"
      ],
      "volume_mappings": {
        "farmos-v4_db": "db",
        "farmos-v4_sites": "sites"
      },
      "port": "8083"
    },
    "dockge": {
      "supported": true,
      "file_based": true,
      "port": "8083\n3307"
    },
    "cosmos": {
      "supported": true,
      "servapp": true,
      "routes_required": true,
      "port": "8083\n3307"
    },
    "umbrel": {
      "supported": true,
      "manifest_version": 1,
      "volume_mappings": {
        "farmos-v4_db": "db",
        "farmos-v4_sites": "sites"
      },
      "port": "8083"
    }
  },
